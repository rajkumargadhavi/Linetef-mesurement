{
  "name": "Linetef",
  "description": "Linetef",
  "version": "2.0.0",
  "manifest_version": 3,
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "action": {
    "default_title": "Linetef",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"]
    }
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "web_accessible_resources": [{
    "resources": ["dist/*"],
    "matches": ["<all_urls>"]
  }]
}